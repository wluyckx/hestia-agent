# --- Required ---
JWT_SECRET=change-me-to-a-random-64-char-string
POC_USERNAME=hestia
POC_PASSWORD_HASH=$2b$12$...   # bcrypt hash of the POC password
ANTHROPIC_API_KEY=sk-ant-...

# --- Backend APIs (Docker network — required for agent data access) ---
ENERGY_BASE_URL=http://p1-api:8000
ENERGY_TOKEN=your-p1-token
SOLAR_BASE_URL=http://sungrow-api:8002
SOLAR_TOKEN=your-sungrow-token
SHOPPING_BASE_URL=http://shopping-api:8080
SHOPPING_API_KEY=your-shopping-key
MEALIE_BASE_URL=http://mealie:9000
MEALIE_TOKEN=your-mealie-token

# --- Optional (defaults shown) ---
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7
